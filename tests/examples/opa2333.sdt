; Dual opamp with different pin counts per unit and various pin styles
# Unit A: First opamp (4 pins) - input, output, power
# Unit B: Second opamp (6 pins) - input, output, enable, clock, power
device opa2333 10 12
unit A
left
i       in-     2
i*      in+     3
right
o       out     1
bottom
a       vcc     4
a       gnd     9
unit B
left
i       in-     6
i-      in+     7
right
o       out     8
o*>     enable  10
bottom
a       vcc     4
a       gnd     9
i>      clk     5
