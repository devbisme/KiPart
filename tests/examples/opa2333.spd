; Dual opamp with different pin counts per unit and various pin styles
// Unit A: First opamp
// Unit B: Second opamp
device opa2333 10 12

    unit A
        left
            i       in-     2
            !in      in+     3
        right
            out       out     1
        bottom
            pi       vcc     4
            pi       gnd     9

    unit B
        left
            i       in-     6
            i-      in+     7  // hidden pin, demonstrating pin sharing
        right
            o_       out     8
            o!>     enable  10
            i_      shutdown 10  ; alternate pin for enable, demonstrating pin sharing
        bottom
            pwr       vcc     4
            po       gnd     9
            i>_      clk     5
